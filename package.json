{
  "name": "@wsocket-io/sdk",
  "version": "0.3.1",
  "description": "wSocket JavaScript SDK — Realtime Pub/Sub client",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "jsdelivr": "dist/wsocket.min.js",
  "unpkg": "dist/wsocket.min.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wsocket-io/sdk-js.git"
  },
  "homepage": "https://wsocket.io",
  "bugs": {
    "url": "https://github.com/wsocket-io/sdk-js/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:cdn": "node build-cdn.js",
    "build:support": "node build-support.js",
    "build:all": "npm run build && npm run build:cdn && npm run build:support",
    "prepublishOnly": "npm run build:all",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "websocket",
    "pubsub",
    "realtime",
    "wsocket"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "@types/node": "^22.12.0",
    "@types/ws": "^8.5.14"
  }
}
